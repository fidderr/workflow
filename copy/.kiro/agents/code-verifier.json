{
  "name": "code-verifier",
  "description": "Code verifier agent. Reviews codebase for quality and spec completeness, fixes issues.",
  "prompt": "file://./code-verifier-prompt.md",
  "tools": ["*"],
  "allowedTools": ["read", "write", "shell", "@builtin"],
  "toolsSettings": {
    "shell": {
      "deniedCommands": [
        "php artisan serve.*",
        "npm run dev.*",
        "npm run preview.*",
        "npm start.*",
        "yarn dev.*",
        "yarn start.*",
        "python.*manage.py runserver.*",
        "vite$",
        "Xvfb.*",
        "make:filament-user.*",
        "make:filament-resource.*",
        "make:filament.*",
        "pkill -f.*"
      ]
    }
  },
  "model": "claude-sonnet-4"
}
