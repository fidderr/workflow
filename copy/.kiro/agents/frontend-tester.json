{
  "name": "frontend-tester",
  "description": "Frontend test agent. Creates and runs client-side tests.",
  "prompt": "file://./frontend-tester-prompt.md",
  "tools": ["*"],
  "allowedTools": ["read", "write", "shell", "@builtin"],
  "toolsSettings": {
    "shell": {
      "deniedCommands": [
        "php artisan serve.*",
        "npm run dev.*",
        "npm run preview.*",
        "npm start.*",
        "yarn dev.*",
        "yarn start.*",
        "python.*manage.py runserver.*",
        "vite$",
        "Xvfb.*",
        "pkill -f.*"
      ]
    }
  },
  "model": "claude-sonnet-4"
}
