{
  "name": "qa",
  "description": "QA agent. Tests the build, takes screenshots, reports bugs, verifies fixes.",
  "prompt": "file://./qa-prompt.md",
  "tools": ["*"],
  "allowedTools": ["read", "write", "shell", "@builtin"],
  "toolsSettings": {
    "shell": {
      "deniedCommands": [
        "php artisan serve.*",
        "npm run dev.*",
        "npm run preview.*",
        "npm start.*",
        "yarn dev.*",
        "yarn start.*",
        "python.*manage.py runserver.*",
        "vite$",
        "make:filament-user.*",
        "make:filament-resource.*",
        "make:filament.*",
        "pkill -f.*"
      ]
    }
  },
  "model": "claude-sonnet-4"
}
